# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=knowbase
POSTGRES_USER=knowbase
POSTGRES_PASSWORD=change-me-strong-password

# ── AI Provider (openai | mistral | ollama) ───────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=
N8N_WEBHOOK_SECRET=change-me-to-a-long-random-string
N8N_ENCRYPTION_KEY=change-me-to-exactly-32-char-string

# ── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Frontend (set at build time or runtime) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
